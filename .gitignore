# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Data (large files, download separately)
data/raw/
data/processed/
*.h5ad
*.h5

# Model checkpoints (download from scGPT model zoo)
checkpoints/
*.pt
*.pth

# Outputs (generated by pipeline runs) — ignore everything under outputs/
# except the whitelisted subtrees below. We cannot blanket-ignore `outputs/`
# because git refuses to re-include files whose parent directory is ignored.
outputs/**

# Keep the small reference TSVs for the eleven-method GRN baseline benchmark
# so the paper's Table 3 numbers are reproducible without rerunning the full
# pipeline.
!outputs/grn_baseline_comparison/
!outputs/grn_baseline_comparison/*.tsv

# LaTeX auxiliary
manuscript/*.aux
manuscript/*.bbl
manuscript/*.blg
manuscript/*.log
manuscript/*.out
manuscript/*.synctex*
manuscript/*.fls
manuscript/*.fdb_latexmk
